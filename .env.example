# ========================================
# Firebase Configuration
# ========================================
# 
# После получения параметров из Firebase Console:
# 1. Создайте файл .env.local в корне проекта
# 2. Скопируйте этот файл и заполните РЕАЛЬНЫМИ значениями
# 3. Файл .env.local НЕ будет включен в Git (см. .gitignore)
#
# Важно: Все переменные React должны начинаться с REACT_APP_
# ========================================

# Скопируйте из Firebase Console → Project Settings → Your apps
REACT_APP_FIREBASE_API_KEY=AIzaSyC1234567890abcdefghijklmnopqrstuvwx
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=123456789012
REACT_APP_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890abcdef

# ВАЖНО: Скопируйте из Realtime Database (вверху страницы)
REACT_APP_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com

# Опционально для аналитики
# REACT_APP_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ========================================
# Как использовать в коде:
# ========================================
#
# const firebaseConfig = {
#   apiKey: process.env.REACT_APP_FIREBASE_API_KEY,
#   authDomain: process.env.REACT_APP_FIREBASE_AUTH_DOMAIN,
#   projectId: process.env.REACT_APP_FIREBASE_PROJECT_ID,
#   storageBucket: process.env.REACT_APP_FIREBASE_STORAGE_BUCKET,
#   messagingSenderId: process.env.REACT_APP_FIREBASE_MESSAGING_SENDER_ID,
#   databaseURL: process.env.REACT_APP_FIREBASE_DATABASE_URL,
#   appId: process.env.REACT_APP_FIREBASE_APP_ID
# };
#
# ========================================
